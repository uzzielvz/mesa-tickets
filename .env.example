NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Asistente IA (Gemini). IMPORTANTE: con datos REALES la key debe ser de un
# proyecto con billing activo (tier de pago) — el tier gratuito de AI Studio
# entrena con los datos.
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Modo demo: las tools del asistente devuelven datos SINTÉTICOS (sin tocar
# Supabase). Permite usar el tier gratuito de Gemini sin exponer datos reales.
AI_ASSISTANT_MOCK=true

# URL del microservicio Python (cartera ETL).
PYTHON_SERVICE_URL=https://crediflexi-services.onrender.com
# Token compartido con el microservicio. Generar con: openssl rand -hex 32
INTERNAL_API_TOKEN=
